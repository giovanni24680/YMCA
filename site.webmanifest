{
  "id": "./",
  "name": "OULM by One YMCA",
  "short_name": "OULM",
  "description": "OULM — Woodland Café, Leavesden, and digital connective tissue for youth community across Hertfordshire, Bedfordshire, and Buckinghamshire.",
  "lang": "en-GB",
  "dir": "ltr",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "browser"],
  "orientation": "any",
  "background_color": "#1a1210",
